CONFIG_TARGET_ipq60xx=y
CONFIG_TARGET_ipq60xx_generic=y
CONFIG_TARGET_ipq60xx_generic_DEVICE_cmiot_ax18=y

# 关闭WiFi
CONFIG_PACKAGE_kmod-qca-wifi=n
CONFIG_PACKAGE_kmod-qca-wifi-unified=n
CONFIG_PACKAGE_wpad-full=n
CONFIG_PACKAGE_wpad-mini=n
CONFIG_PACKAGE_hostapd=n
CONFIG_PACKAGE_iw=n
CONFIG_PACKAGE_iwinfo=n

# 基础
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_openssh-sftp-server=y

# 内存/CPU
CONFIG_PACKAGE_luci-app-ramfree=y
CONFIG_PACKAGE_luci-app-cpu-frequency=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y

# IPv6
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_luci-proto-ipv6=y

# iStore
CONFIG_PACKAGE_luci-app-store=y

# MWAN3
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-app-mwan3helper=y

# UPnP
CONFIG_PACKAGE_luci-app-upnp=y

# OAF
CONFIG_PACKAGE_luci-app-openappfilter=y

# Samba4
CONFIG_PACKAGE_luci-app-samba4=y

# SmartDNS + 广告屏蔽
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-app-adbyby-plus=y

# 科学
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-wireguard=y

# KMS
CONFIG_PACKAGE_luci-app-kms=y

# DDNS
CONFIG_PACKAGE_luci-app-ddns=y

# 监控
CONFIG_PACKAGE_luci-app-vnstat2=y
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-app-netdata=y

# QoS
CONFIG_PACKAGE_luci-app-qos=y
CONFIG_PACKAGE_luci-app-sqm=y
